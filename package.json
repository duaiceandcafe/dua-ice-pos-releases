{
  "name": "dua-ice-pos",
  "version": "1.0.4",
  "description": "Dua Ice & Cafe — Point of Sale",
  "main": "main.js",
  "author": "Dua Ice & Cafe",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --publish always",
    "publish:win": "electron-builder --win --publish always",
    "publish:mac": "electron-builder --mac --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.duaicecafe.pos",
    "productName": "Dua Ice POS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "duaiceandcafe",
        "repo": "dua-ice-pos-releases",
        "private": false,
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "publisherName": "Dua Ice & Cafe"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dua Ice POS",
      "differentialPackage": true
    }
  }
}
